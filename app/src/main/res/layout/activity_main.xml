<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- 앱 제목 -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="110dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="산수화 (SL Partner)"
            android:textColor="@color/text_primary"
            android:textSize="36sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="긴급상황 수어 번역 서비스"
            android:textAlignment="center"
            android:textColor="@color/text_secondary"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- 버튼 -->
    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp">

        <!-- 녹화하기 버튼 -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_video"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/button_gradient_primary"
            android:drawableLeft="@android:drawable/ic_menu_camera"
            android:drawablePadding="12dp"
            android:drawableTint="@color/white"
            android:elevation="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="수화 녹화하기"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <!-- 갤러리 탐색 버튼 -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_gallery"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/button_gradient_secondary"
            android:drawableLeft="@android:drawable/ic_menu_gallery"
            android:drawablePadding="12dp"
            android:drawableTint="@color/white"
            android:elevation="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="갤러리 탐색"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <!-- 팁 문구 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="팁: 더 나은 인식을 위해 조명을 밝게 해주세요"
            android:textColor="@color/accent_cyan"
            android:textSize="14sp"
            android:textAlignment="center" />

    </LinearLayout>
</RelativeLayout>